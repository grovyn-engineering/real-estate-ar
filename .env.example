# ── Cloudflare R2 (asset upload, dev/CI only) ──────────────────────────────
# Get these from: Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ar-vr
R2_API_TOKEN=
S3_API_ENDPOINT=

# ── CDN public URL (used by the app at runtime) ─────────────────────────────
# Set this to your R2 public bucket URL or custom domain.
# Leave empty in local dev - assets are served from /public instead.
VITE_CDN_BASE_URL=

# ── Host port for the production container (docker compose) ─────────────────
# The container listens on 80 internally; this maps it to a host port.
# Defaults to 8080. Override if 8080 is taken on the host (e.g. 3000, 8090).
APP_PORT=8080

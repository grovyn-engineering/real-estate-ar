# CDN base URL for 3D models and 360° panoramas.
# Leave empty to serve from local /public (dev only).
# In production set this to your CDN domain, e.g.:
#   Cloudflare R2:  https://assets.yourdomain.com
#   AWS CloudFront: https://d1234abcd.cloudfront.net
#   Bunny.net:      https://grovyn.b-cdn.net
VITE_CDN_BASE_URL=

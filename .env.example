# ── Cloudflare R2 (asset upload, dev/CI only) ──────────────────────────────
# Get these from: Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=grovyn-assets

# ── CDN public URL (used by the app at runtime) ─────────────────────────────
# Set this to your R2 public bucket URL or custom domain.
# Leave empty in local dev — assets are served from /public instead.
VITE_CDN_BASE_URL=
